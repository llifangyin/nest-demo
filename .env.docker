# ---- HTTP 端口 ----
PORT=3000

# ---- MongoDB（服务名 mongodb，不是 localhost！）----
# MONGODB_URI=mongodb://zanyu:Password01!@mongodb:27017/nest-demo?authSource=admin
MONGODB_URI=mongodb://root:Password01!@mongodb:27017/nest-demo?authSource=admin
MONGO_ROOT_USER=root
MONGO_ROOT_PASS=Password01!
MONGO_DB_NAME=nest-demo
ADMIN_INIT_PASSWORD=Password01!
ADMIN_INIT_EMAIL=admin@example.com
# ---- Redis（服务名 redis）----
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASS=Password01!

# ---- RabbitMQ（服务名 rabbitmq）----
RABBITMQ_URL=amqp://admin:Password01!@rabbitmq:5672
RABBITMQ_USER=admin
RABBITMQ_PASS=Password01!

# ---- TCP 微服务地址（Docker 容器服务名）----
USER_SERVICE_HOST=user-service
PRODUCT_SERVICE_HOST=product-service

